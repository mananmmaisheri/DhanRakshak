rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Connection Test Node
    // Used by src/lib/firebase.ts to verify connectivity
    match /test/connection {
      allow get: if true;
    }

    // 3. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isVerified() && (
        request.auth.token.email == "mananmmaisheri23@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid 
            && data.email is string && data.email.size() <= 256
            && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
            && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000));
      }

      allow get: if isValidId(userId) && (isOwner(userId) || isAdmin());
      allow create: if isValidId(userId) && isOwner(userId) && isVerified() && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isValidId(userId) && (isOwner(userId) || isAdmin()) 
                    && isVerified()
                    && isValidUser(incoming()) 
                    && (
                      isAdmin() || (
                        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt'])
                        && incoming().updatedAt == request.time
                        && incoming().uid == existing().uid
                        && incoming().email == existing().email
                      )
                    );
    }

    // 2. Transactions
    match /transactions/{transactionId} {
      function isValidTransaction(data) {
        return data.userId == request.auth.uid
            && data.amount is number
            && data.merchant is string && data.merchant.size() <= 100
            && data.date is string && data.date.size() <= 64;
      }

      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow get: if isValidId(transactionId) && isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(transactionId) && isVerified() 
                    && isValidTransaction(incoming()) 
                    && incoming().userId == request.auth.uid;
      allow delete: if isValidId(transactionId) && isVerified() && resource.data.userId == request.auth.uid;
    }

    // 3. Subscriptions
    match /subscriptions/{subId} {
      function isValidSubscription(data) {
        return data.userId == request.auth.uid
            && data.provider is string && data.provider.size() <= 100
            && data.currentPrice is number
            && data.status in ['active', 'negotiating', 'secured'];
      }

      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow get: if isValidId(subId) && isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(subId) && isVerified() 
                    && isValidSubscription(incoming())
                    && incoming().userId == request.auth.uid;
      allow update: if isValidId(subId) && isVerified() 
                    && resource.data.userId == request.auth.uid
                    && isValidSubscription(incoming())
                    && (
                      // Transition: Negotiation State
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'targetPrice', 'updatedAt'])
                      && (incoming().updatedAt == request.time || !('updatedAt' in incoming()))
                    );
    }
  }
}
