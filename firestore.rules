rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid 
            && data.email is string 
            && data.email.size() <= 256;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
                    && isValidUser(incoming()) 
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // 2. Transactions
    match /transactions/{transactionId} {
      function isValidTransaction(data) {
        return data.userId == request.auth.uid
            && data.amount is number
            && data.merchant is string && data.merchant.size() <= 100
            && data.date is string;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
                    && isValidTransaction(incoming()) 
                    && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 3. Subscriptions
    match /subscriptions/{subId} {
      function isValidSubscription(data) {
        return data.userId == request.auth.uid
            && data.provider is string && data.provider.size() <= 100
            && data.currentPrice is number
            && data.status in ['active', 'negotiating', 'secured'];
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
                    && isValidSubscription(incoming())
                    && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() 
                    && resource.data.userId == request.auth.uid
                    && isValidSubscription(incoming())
                    && (
                      // Transition: Negotiation State
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'targetPrice'])
                    );
    }
  }
}
